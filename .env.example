# Database (Prisma). SQLite for local dev; swap the provider in prisma/schema.prisma
# to "postgresql" and point this at a Postgres connection string for production.
DATABASE_URL="file:./dev.db"

# Secret used to sign session JWTs (and the short-lived step-up tokens for
# the opt-in "require a fresh signature before changes" setting - see the
# README "Session hardening" section). Must be at least 32 characters
# (enforced at startup). Generate a strong random value, e.g.:
#   openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret-32ch"

# --- Avian namespace ("*.avn" names) --------------------------------------

# DNS zone hosted on PowerDNS. ANS name "bob.avn" maps to "bob.avn.zone"
# under this root (see src/lib/namespaces/avian.ts).
AVIAN_DNS_ZONE="avn.zone"

# Avian ANS ownership provider. If AVIAN_RPC_URL/USER/PASSWORD are all set
# below, the app uses AviandRpcAnsOwnershipProvider (real on-chain lookups via
# aviand's asset index). Otherwise it falls back to the env-driven
# MockAnsOwnershipProvider (see src/lib/ownership/avian/mock-provider.ts) -
# handy for local development/testing without a node.
AVIAN_MOCK_OWNERS={"bob.avn":"RAddressOwningBobDotAvn","alice.avn":"RAddressOwningAliceDotAvn"}

# aviand (Avian Core) JSON-RPC connection, used by AviandRpcAnsOwnershipProvider
# (src/lib/ownership/avian/rpc-provider.ts) to resolve real ANS ownership. The
# node MUST be started with -assetindex=1 (or assetindex=1 in avian.conf) for
# the listaddressesbyasset / listassetbalancesbyaddress RPCs to work. Leave
# unset to use the mock provider instead.
# AVIAN_RPC_URL="http://127.0.0.1:<rpcport-from-your-avian.conf>"
# AVIAN_RPC_USER="rpcuser"
# AVIAN_RPC_PASSWORD="rpcpassword"
# AVIAN_RPC_TIMEOUT_MS="10000"

# Message prefix used when verifying Avian "sign message" signatures. Avian is
# a fork of Ravencoin and kept its original message magic string, so this is
# "Raven Signed Message:\n" (matches the built-in default in
# src/lib/ownership/avian/message.ts). Only set this if a future Avian Core
# release changes it.
AVIAN_MESSAGE_PREFIX="Raven Signed Message:\n"

# --- Radiant namespace ("*.rxd" names) ------------------------------------

# DNS zone hosted on PowerDNS. Wave name "bob.rxd" maps to "bob.rxd.zone"
# under this root (see src/lib/namespaces/radiant.ts).
RADIANT_DNS_ZONE="rxd.zone"

# Radiant Wave Names ownership provider. If RADIANT_ELECTRUMX_HOST/PORT are
# both set below, the app uses ElectrumRadiantOwnershipLookup (real on-chain
# lookups via an RXinDexer instance's wave.reverse_lookup/wave.resolve
# methods - see src/lib/ownership/radiant/wave.ts). Otherwise it falls back
# to the env-driven MockRadiantOwnershipLookup (see
# src/lib/ownership/radiant/mock-provider.ts) - handy for local development
# without a live RXinDexer instance.
RADIANT_MOCK_OWNERS={"bob.rxd":"1AddressOwningBobDotRxd"}

# RXinDexer (an ElectrumX fork/extension understanding Radiant's Wave/Glyphs
# protocol) plain-TCP JSON-RPC connection, used by ElectrumRadiantOwnershipLookup
# (src/lib/ownership/radiant/electrum-provider.ts) to resolve real Wave name
# ownership. Not HTTPS/SSL - a raw newline-delimited JSON-RPC 2.0 socket.
# Leave unset to use the mock provider instead.
# RADIANT_ELECTRUMX_HOST="10.10.30.205"
# RADIANT_ELECTRUMX_PORT="50010"
# RADIANT_ELECTRUMX_TIMEOUT_MS="10000"

# Message prefix used when verifying Radiant "sign message" signatures.
# Radiant kept Bitcoin's address format, so this defaults to
# bitcoinjs-message's built-in "Bitcoin Signed Message:\n" (left unset below -
# see src/lib/ownership/radiant/message.ts). This is a best-effort guess, not
# yet confirmed against a real Radiant Core/Photonic-produced signature -
# only set this if that turns out to be wrong.
# RADIANT_MESSAGE_PREFIX="Bitcoin Signed Message:\n"

# --- Shared / infrastructure -----------------------------------------------

# PowerDNS Authoritative HTTP API (one shared instance across all namespaces;
# each namespace manages its own zone on it). If left blank, the app runs in
# "dry run" mode: DNS writes are logged instead of sent, which is useful for
# local development without a running PowerDNS instance.
POWERDNS_API_URL="http://127.0.0.1:8081"
POWERDNS_API_KEY="changeme"
POWERDNS_SERVER_ID="localhost"
# Set to "true" to trigger a notify to secondaries after each write.
POWERDNS_NOTIFY="false"

# Max DNS write requests allowed per address per rolling minute.
RATE_LIMIT_DNS_WRITES_PER_MINUTE="20"

# How many on-chain ownership lookups the cron sweep (POST
# /api/cron/verify-ownership) runs concurrently. The sweep's runtime is
# dominated by lookup round-trips, so this divides its wall time; keep it
# modest to avoid hammering the indexer/RPC nodes. Default 5.
OWNERSHIP_SWEEP_CONCURRENCY="5"

# --- Email records (MX / SPF / DKIM / DMARC) -------------------------------
# Comma-separated allowlist of full source names permitted to create email
# records. Empty/unset (the default) means NO name can - the general DNS
# flow stays A/AAAA/CNAME + ACME TXT only. Email is allowlist-gated because
# sending mail under the shared parent zone stakes the WHOLE zone's
# reputation, so it's operator-granted to known names, not permissionless.
#
# Before enabling ANY name, publish these at each zone apex by hand (they
# make every NON-allowlisted subdomain hard-fail spoofing by default;
# allowlisted names override with their own _dmarc):
#   pdnsutil add-record rxd.zone rxd.zone TXT 3600 '"v=spf1 -all"'
#   pdnsutil add-record rxd.zone _dmarc.rxd.zone TXT 3600 '"v=DMARC1; p=reject; sp=reject;"'
#   (repeat for avn.zone; then increase-serial + notify)
# EMAIL_ALLOWED_NAMES="craigd.rxd,art.rxd"

# Shared secret for POST /api/cron/verify-ownership (the background ownership
# watcher, sweeping every enabled namespace - see README "Ownership transfer
# handling"). Required for that route to do anything; without it the route
# always returns 503. Generate with e.g. `openssl rand -hex 32` and wire up an
# external scheduler (system cron, systemd timer, Vercel Cron, GitHub Actions
# schedule) to POST to it every 5-10 minutes with
# `Authorization: Bearer <this value>`.
CRON_SECRET="replace-with-a-long-random-secret"

# Public base URL, used to resolve absolute Open Graph/social preview image
# URLs. Defaults to http://localhost:3000 if unset.
# NEXT_PUBLIC_APP_URL="https://your-deployed-domain.example"

# Abuse-report contact shown on each namespace's Help page (/help#abuse).
# Must be a real, monitored inbox - a visible abuse contact is required for
# Public Suffix List inclusion, and PSL inquiries expect responses within
# 30 days.
# ABUSE_CONTACT_EMAIL="abuse-reports@example.com"

# Overrides the Photonic wallet connect URL for local Photonic development
# (e.g. a dev build at http://localhost:5173/#/connect). NEXT_PUBLIC_, so it
# is inlined at build time - set it before `next build`, not just at runtime.
# NEXT_PUBLIC_PHOTONIC_CONNECT_URL="https://photonic-wallet.com/#/connect"

# Official project names: a JSON map of full source name -> the project-held
# owner address (one flat map covers all namespaces - names carry their TLD).
# A name shows the "Official" badge (lookup page, /official page, and
# GET /api/[namespace]/verified) only while its CURRENT on-chain owner
# matches this address - if the asset is sold or transferred, the badge
# drops automatically. Unset means no name is marked official anywhere.
# VERIFIED_TEAM_NAMES={"brand.avn":"RTeamAddress...","brand.rxd":"1TeamAddress..."}
